{
  "name": "bookstore-frontend",
  "version": "1.1.2",
  "description": "Premium E-commerce Bookstore Frontend built with Next.js 16",
  "author": "JasonTM17",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "start:local": "node scripts/start-standalone.mjs --port 3001 --rebuild --kill-port",
    "restart:local": "npm run start:local",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:portfolio": "playwright test e2e/portfolio-cta-smoke.spec.ts e2e/portfolio-audit.spec.ts --project=chromium --workers=1",
    "test:e2e:portfolio-audit": "playwright test e2e/portfolio-audit.spec.ts --project=chromium --workers=1",
    "test:e2e:admin-portfolio": "playwright test e2e/admin-portfolio.spec.ts --project=chromium --project=\"Mobile Chrome\" --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@swc/helpers": "^0.5.21",
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.1.6",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.414.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^2.12.7",
    "sharp": "^0.33.5",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "use-debounce": "^10.1.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^24.1.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
