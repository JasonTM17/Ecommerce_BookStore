# BookStore Application Environment Variables

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# ===========================================
# JWT Configuration (MUST be at least 256 bits)
# ===========================================
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationThatShouldBeAtLeast256BitsLong!
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===========================================
# Application Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_BASE_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=uploads

# ===========================================
# Email Configuration (Gmail SMTP)
# IMPORTANT: Use App Password, NOT your account password
# Get it at: https://myaccount.google.com/security -> App Passwords
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=noreply@bookstore.com
APP_EMAIL_SENDER_NAME=BookStore Team

# ===========================================
# Email Test Endpoints (Dev only - DISABLE in prod!)
# ===========================================
APP_EMAIL_TEST_ENABLED=true
APP_EMAIL_ALLOWED_RECIPIENTS=your-test-email@gmail.com

# ===========================================
# Rate Limiting Configuration
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_API_LIMIT=100
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_LIMIT=200
RATE_LIMIT_PUBLIC_WINDOW_MS=60000

# ===========================================
# Input Validation Configuration
# ===========================================
INPUT_VALIDATION_ENABLED=true
INPUT_VALIDATION_MAX_BODY_SIZE=10485760
INPUT_VALIDATION_BLOCK_XSS=true
INPUT_VALIDATION_BLOCK_SQL_INJECTION=true

# ===========================================
# Newsletter Configuration
# ===========================================
NEWSLETTER_ENABLED=true
NEWSLETTER_CRON=0 0 9 ? * SUN

# ===========================================
# Frontend Environment
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=BookStore
NEXT_PUBLIC_APP_DESCRIPTION=Professional Vietnamese E-Commerce BookStore Platform

# ===========================================
# Security Notes:
# 1. NEVER commit .env file to git!
# 2. Use strong JWT_SECRET (at least 32 characters)
# 3. Use App Password for Gmail (not account password)
# 4. Disable test endpoints in production
# 5. Enable rate limiting in production

# ===========================================
# Grok AI Chatbot Configuration
# Get your API key at: https://console.x.ai/
# ===========================================
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-3
GROK_API_URL=https://api.x.ai/v1/chat/completions
