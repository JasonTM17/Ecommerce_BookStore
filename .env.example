# BookStore Application Environment Variables

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=replace-with-private-mysql-root-password
POSTGRES_PASSWORD=replace-with-private-postgres-password

# ===========================================
# JWT Configuration (MUST be at least 256 bits)
# ===========================================
JWT_SECRET=replace-with-at-least-32-byte-random-secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===========================================
# Application Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_BASE_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=uploads

# ===========================================
# Email Configuration (Gmail SMTP)
# IMPORTANT: Use App Password, NOT your account password
# Get it at: https://myaccount.google.com/security -> App Passwords
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=noreply@bookstore.com
APP_EMAIL_SENDER_NAME=BookStore Team

# ===========================================
# Email Test Endpoints (Dev only - DISABLE in prod!)
# ===========================================
APP_EMAIL_TEST_ENABLED=true
APP_EMAIL_ALLOWED_RECIPIENTS=your-test-email@gmail.com

# ===========================================
# Rate Limiting Configuration
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_API_LIMIT=100
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_LIMIT=200
RATE_LIMIT_PUBLIC_WINDOW_MS=60000

# ===========================================
# Input Validation Configuration
# ===========================================
INPUT_VALIDATION_ENABLED=true
INPUT_VALIDATION_MAX_BODY_SIZE=10485760
INPUT_VALIDATION_BLOCK_XSS=true
INPUT_VALIDATION_BLOCK_SQL_INJECTION=true

# ===========================================
# Newsletter Configuration
# ===========================================
NEWSLETTER_ENABLED=true
NEWSLETTER_CRON=0 0 9 ? * SUN

# ===========================================
# Flash Sale Automation
# ===========================================
# Weekly auto-rotation for the next flash-sale campaign.
FLASHSALE_AUTO_ENABLED=true
FLASHSALE_AUTO_CRON=0 5 0 ? * MON
FLASHSALE_AUTO_TIMEZONE=Asia/Bangkok
FLASHSALE_AUTO_BATCH_SIZE=4
FLASHSALE_AUTO_DISCOUNT_MIN=15
FLASHSALE_AUTO_DISCOUNT_MAX=30
FLASHSALE_AUTO_STOCK_MIN=20
FLASHSALE_AUTO_STOCK_MAX=60
FLASHSALE_AUTO_MAX_PER_USER=2

# ===========================================
# VNPay Configuration (optional)
# ===========================================
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_MERCHANT_ID=your-merchant-id
VNPAY_MERCHANT_KEY=your-merchant-key
VNPAY_RETURN_URL=http://localhost:3001/payment/return
VNPAY_IPN_URL=http://localhost:8080/api/payments/vnpay/ipn

# ===========================================
# Portfolio Demo Seed
# ===========================================
APP_DEMO_SEED_ENABLED=false
APP_DEMO_SEED_DEFERRED=false
APP_DEMO_ADMIN_PASSWORD=replace-with-private-demo-admin-password
APP_DEMO_MANAGER_PASSWORD=replace-with-private-demo-manager-password
APP_DEMO_CUSTOMER_PASSWORD=replace-with-private-demo-customer-password

# ===========================================
# Frontend Environment
# ===========================================
# Use the Next.js API proxy by default so local frontend can load data even
# when the Spring Boot backend is remote or still cold-starting.
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=https://bookstore-api-a1xl.onrender.com/api
API_PROXY_TIMEOUT_MS=65000
NEXT_PUBLIC_APP_NAME=BookStore
NEXT_PUBLIC_APP_DESCRIPTION=Professional Vietnamese E-Commerce BookStore Platform
NEXT_PUBLIC_VNPAY_ENABLED=false

# ===========================================
# Security Notes:
# 1. NEVER commit .env file to git!
# 2. Use strong JWT_SECRET (at least 32 characters)
# 3. Use App Password for Gmail (not account password)
# 4. Disable test endpoints in production
# 5. Enable rate limiting in production

# ===========================================
# Grok AI Chatbot Configuration
# Get your API key at: https://console.x.ai/
# ===========================================
GROK_ENABLED=false
# Set GROK_ENABLED=true together with GROK_API_KEY to enable Grok in local/dev.
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-3
GROK_API_URL=https://api.x.ai/v1/chat/completions
