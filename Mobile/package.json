{
  "name": "bookstore-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios"
  },
  "dependencies": {
    "expo": "~50.0.0",
    "expo-status-bar": "~1.11.1",
    "expo-constants": "~15.4.5",
    "expo-font": "~11.10.3",
    "expo-location": "~16.5.5",
    "expo-notifications": "~0.27.7",
    "expo-camera": "~14.1.3",
    "expo-barcode-scanner": "~12.9.3",
    "expo-local-authentication": "~13.8.0",
    "expo-secure-store": "~12.8.1",
    "expo-splash-screen": "~0.26.4",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.8",
    "zustand": "^4.5.2",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-gesture-handler": "~2.14.1",
    "react-native-reanimated": "~3.6.2",
    "nativewind": "^2.0.11",
    "tailwindcss": "^3.3.2",
    "lucide-react-native": "^0.356.0",
    "@expo/vector-icons": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "typescript": "^5.1.3"
  },
  "expo": {
    "name": "BookStore Mobile",
    "slug": "bookstore-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookstore.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bookstore.mobile",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-local-authentication",
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép BookStore truy cập camera để quét mã vạch ISBN"
        }
      ]
    ]
  }
}
