# ===========================================
# Email Test Configuration
# ===========================================
# Configure your Gmail App Password here for testing
# Get App Password: https://myaccount.google.com/security -> App Passwords

# Email credentials (REPLACE WITH YOUR OWN!)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=noreply@bookstore.com

# Test recipient (your email to receive test emails)
APP_EMAIL_ALLOWED_RECIPIENTS=your-email@gmail.com

# Enable email test endpoints (for development only)
APP_EMAIL_TEST_ENABLED=true

# ===========================================
# Application Settings
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore
DB_USERNAME=postgres
DB_PASSWORD=postgres

JWT_SECRET=TestSecretKeyForJWTTokenGenerationThatShouldBeAtLeast256BitsLongForTestingPurpose!
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_BASE_URL=http://localhost:3000
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# Security Settings (Test Environment)
# ===========================================
RATE_LIMIT_ENABLED=false
INPUT_VALIDATION_ENABLED=true

# ===========================================
# Test User Credentials
# ===========================================
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=Test123456
ADMIN_EMAIL=admin@bookstore.com
ADMIN_PASSWORD=Admin123456
